# ── Required ──────────────────────────────────────────────────────────────────
# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional (enables real-time web search) ───────────────────────────────────
# Google Custom Search API key — https://console.cloud.google.com/
# Enable "Custom Search API" and create a key under APIs & Services > Credentials
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here

# Programmable Search Engine ID — https://programmablesearchengine.google.com/
# Create an engine, enable "Search the entire web", then copy the ID (cx)
GOOGLE_SEARCH_CX=your_search_engine_cx_here

# ── Flask (auto-generated, change if needed) ─────────────────────────────────
SECRET_KEY=change-me-to-a-random-string
